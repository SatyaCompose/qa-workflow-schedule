# Asana
ASANA_TOKEN=your_asana_personal_access_token
ASANA_PROJECT_GID=56687465655        # the project/board to read from
ASANA_SOURCE_USER_GIDS=111,222      # comma-separated, the 2 source users
ASANA_SPRINT_GIDS=333,444           # comma-separated, the 2 source users

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # service role, server-side only

# Cron protection (Vercel sets this automatically; required for /api/cron/*)
CRON_SECRET=some_random_string
