# Asana (read-only)
ASANA_TOKEN=your_asana_personal_access_token
ASANA_PROJECT_GID=1212994117899188              # the project containing all sprint tasks
ASANA_SOURCE_USER_GIDS=111,222                  # comma-separated, the 2 source users (these ARE Asana users)
ASANA_SPRINTS=Sprint 13                         # comma-separated sprint names (matched against the "Sprint Allocation" custom field)

# Target users — these are QA team members tracked only in this app.
# They do NOT need Asana accounts. Comma-separated names.
TARGET_USERS=Person 1,Person 2,Person 3

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # service role, server-side only

# Cron protection (required for /api/cron/*)
CRON_SECRET=some_random_string

# Admin password for manual ticket reassignment (Basic Auth on /api/admin/*)
ADMIN_PASSWORD=pick_something_random
