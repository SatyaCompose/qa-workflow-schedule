# Asana (read-only)
ASANA_TOKEN=your_asana_personal_access_token
ASANA_WORKSPACE_GID=194367843040                # workspace ID (from app.asana.com/1/<workspace>/...)
ASANA_SOURCE_USER_GIDS=111,222                  # comma-separated, the 2 source users (these ARE Asana users)

# Sprint project name prefixes (case-insensitive "starts with").
# Any Asana project whose name starts with one of these is treated as a sprint.
# Order = sprint age. First listed is the oldest = highest priority.
# e.g. ASANA_SPRINTS=Sprint 12 matches "Sprint 12 - 2026 - Website Development"
ASANA_SPRINTS=Sprint 12,Sprint 13

# Target users. Comma-separated entries. Each entry is either:
#   "Name"             — target with no Asana account (e.g. Vardhan)
#   "Name:asana_gid"   — target who also has an Asana account; their Asana
#                        tickets lock to them (e.g. Anand's tickets go to Anand)
# Example:
TARGET_USERS=Nrushimha:1206062910348908,Vardhan,Anand:1214565506138398

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # service role, server-side only

# Cron protection (required for /api/cron/*)
CRON_SECRET=some_random_string

# Admin password for manual ticket reassignment (Basic Auth on /api/admin/*)
ADMIN_PASSWORD=pick_something_random
